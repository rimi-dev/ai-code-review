{
  "uid": "llm-provider-performance",
  "title": "LLM Provider Performance",
  "tags": ["review-bot", "llm"],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Response Time by Provider (Histogram)",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (le, provider) (rate(review_duration_seconds_bucket[5m]))",
          "legendFormat": "{{ provider }} - {{ le }}",
          "format": "heatmap"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error Rate by Provider",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (provider) (rate(review_total{status=\"FAILED\"}[5m])) / sum by (provider) (rate(review_total[5m])) * 100",
          "legendFormat": "{{ provider }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "fillOpacity": 20
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Circuit Breaker State",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "model_circuit_state",
          "legendFormat": "{{ provider }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "CLOSED", "color": "green" } } },
            { "type": "value", "options": { "1": { "text": "OPEN", "color": "red" } } },
            { "type": "value", "options": { "2": { "text": "HALF_OPEN", "color": "yellow" } } }
          ]
        }
      }
    },
    {
      "id": 4,
      "title": "Fallback Trend",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (from_provider, to_provider) (rate(review_fallback_total[5m]))",
          "legendFormat": "{{ from_provider }} -> {{ to_provider }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 30
          }
        }
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
